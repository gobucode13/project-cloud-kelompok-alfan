# =========================================
# DATABASE (MySQL)
# =========================================
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_DATABASE=wordpress_db
MYSQL_USER=wp_user
MYSQL_PASSWORD=changeme_wp_password

# =========================================
# OBJECT STORAGE (MinIO)
# =========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_BUCKET=wp-media

# =========================================
# WORDPRESS (digunakan oleh plugin S3 Uploads / WP Offload Media)
# =========================================
WP_S3_ENDPOINT=http://minio:9000
WP_S3_ACCESS_KEY=${MINIO_ROOT_USER}
WP_S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}
WP_S3_BUCKET=${MINIO_BUCKET}
WP_S3_REGION=us-east-1
